# ─── itopy.ai Dashboard — Variables de entorno ───────────────────────────────
# Copia a .env y rellena los valores reales

# Seguridad
DASHBOARD_SECRET=cambia_esto_por_una_clave_segura
PORT=3050

# Notion
NOTION_TOKEN=secret_...

# Google Calendar (Service Account JSON path)
GOOGLE_CREDENTIALS_PATH=/opt/itopy.ai/apps/agents/ap_antigravity/credentials.json
GOOGLE_CALENDAR_ID=primary

# n8n
N8N_BASE_URL=https://n8n.itopy.ai
N8N_API_KEY=               # Opcional, si tienes API key de n8n
N8N_GMAIL_WEBHOOK=https://n8n.itopy.ai/webhook/gmail-search

# Notion DB IDs
NOTION_TASKS_DB=2c013215d8274015b39a184debe778ba
NOTION_PROJECTS_DB=16f98a53858d45d39d86ae8d6ace5244

# Docker socket (para VPS status)
DOCKER_SOCKET=/var/run/docker.sock
